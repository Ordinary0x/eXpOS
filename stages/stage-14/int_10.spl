alias currentPID R0;
currentPID = [SYSTEM_STATUS_TABLE+1];

alias process_table_entry R1;
process_table_entry = PROCESS_TABLE + currentPID * 16;

[process_table_entry + 4] = TERMINATED;

alias state R3;
alias i R2;

i=1;
while (i<16)do 
    state = [PROCESS_TABLE + i*16 +4];
    if(state != TERMINATED)then
        call MOD_5;
    endif;
    i=i+1;
endwhile;

halt;
